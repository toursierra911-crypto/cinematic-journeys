{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "framework": null,
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/@/:path*", "destination": "/:path*" },
    { "source": "/assets/:path*", "destination": "/assets/:path*" }
  ],
  "functions": {
    "api/index.js": {
      "runtime": "nodejs@20"
    }
  }
}